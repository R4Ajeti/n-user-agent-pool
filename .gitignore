# ==============================================================================
# n_user_agent_pool .gitignore
# Python + Codex + Chrome user-agent pool project
# ==============================================================================


# ------------------------------------------------------------------------------
# Python bytecode / cache
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.dmypy.json
dmypy.json


# ------------------------------------------------------------------------------
# Virtual environments
# ------------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.nox/
.tox/


# ------------------------------------------------------------------------------
# Environment variables / secrets
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template
*.env
*.secret
*.secrets
*.key
*.pem
*.p12
*.pfx
*.crt
*.csr
*.jks
*.keystore
secrets/
secret/
credential/
credentials/
private/
private_key*
id_rsa*
id_ed25519*


# ------------------------------------------------------------------------------
# User-agent pool sensitive runtime data
# ------------------------------------------------------------------------------
proxy.txt
proxy_list.txt
proxy-list.txt
proxy_pool.txt
ip_pool.txt
working_proxy.txt
working_proxies.txt
failed_proxy.txt
failed_proxies.txt
blacklist.txt
whitelist.txt
proxy_result/
proxy_results/
proxy_dump/
proxy_cache/
proxy_runtime/
proxy_session/
proxy_credential/
proxy_credentials/
*.proxy
*.proxy.txt


# ------------------------------------------------------------------------------
# Experimental / local research resources
# ------------------------------------------------------------------------------
/*[A-Z]*.py
experimental-resource/
experiment/
experiment-output/
sandbox/
scratch/
tmp/
temp/


# ------------------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------------------
*.log
*.log.*
log/
logs/
runtime.log
debug.log
error.log
access.log


# ------------------------------------------------------------------------------
# Build / packaging output
# ------------------------------------------------------------------------------
build/
dist/
site/
.eggs/
*.egg-info/
*.egg
pip-wheel-metadata/
wheelhouse/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
*.py,cover


# ------------------------------------------------------------------------------
# Test output / reports
# ------------------------------------------------------------------------------
report/
reports/
test-report/
test-reports/
junit.xml
pytest-report.xml
coverage-report/


# ------------------------------------------------------------------------------
# Local databases / storage
# ------------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.duckdb
*.db-journal
data/local/
local-data/
storage/local/


# ------------------------------------------------------------------------------
# Jupyter / notebooks
# ------------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb


# ------------------------------------------------------------------------------
# IDE / editor files
# ------------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.swn
*.sublime-project
*.sublime-workspace


# ------------------------------------------------------------------------------
# macOS
# ------------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
.fseventsd


# ------------------------------------------------------------------------------
# Windows
# ------------------------------------------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/


# ------------------------------------------------------------------------------
# Linux
# ------------------------------------------------------------------------------
*~
.directory
.Trash-*


# ------------------------------------------------------------------------------
# Node / frontend tools, in case docs or tooling use JS later
# ------------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.next/
.nuxt/
.svelte-kit/


# ------------------------------------------------------------------------------
# Codex / AI assistant local artifacts
# Keep AGENTS.md and skill/ committed.
# Ignore temporary assistant outputs only.
# ------------------------------------------------------------------------------
.codex/
.codex-cache/
codex-output/
codex_tmp/
ai-output/
ai-draft/
prompt-output/


# ------------------------------------------------------------------------------
# Claude local artifacts
# Keep only if you later decide to use Claude.
# ------------------------------------------------------------------------------
.claude/settings.local.json


# ------------------------------------------------------------------------------
# Docker / local infra
# ------------------------------------------------------------------------------
.docker/
docker-compose.override.yml
*.pid


# ------------------------------------------------------------------------------
# Cloud credentials and local provider config
# ------------------------------------------------------------------------------
.aws/
.gcp/
.azure/
terraform.tfstate
terraform.tfstate.*
.terraform/
.terraform.lock.hcl
*.tfvars
*.tfvars.json


# ------------------------------------------------------------------------------
# Keep important templates
# ------------------------------------------------------------------------------
!.gitkeep
!README.md
!AGENTS.md
!skill/
!skill/**/SKILL.md
commands.txt
key-val-load-test-log.txt
key-val-load-test-result.json
